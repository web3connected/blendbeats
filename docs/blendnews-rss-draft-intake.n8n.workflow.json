      "position": [
        100,
        120
      ]
    },
    {
      "parameters": {
        "jsCode": "const sourceUrl = $json.link || $json.url || '';\nconst sourceGuid = $json.guid || $json.id || sourceUrl;\nconst summary = $json.contentSnippet || $json.content || $json.description || '';\n\nreturn [\n  {\n    json: {\n      source_name: 'RSS Feed',\n      source_url: sourceUrl,\n      source_feed_url: '<RSS_FEED_URL>',\n      source_guid: sourceGuid,\n      original_title: $json.title || 'Untitled RSS item',\n      title: $json.title || 'Untitled RSS item',\n      summary,\n      status: 'needs_review',\n      content_type: 'news',\n      category_slug: null,\n      metadata: {\n        created_by_automation: true,\n        workflow_name: 'BlendNews RSS Draft Intake',\n        rss_published_at: $json.pubDate || $json.isoDate || null\n      }\n    }\n  }\n];"
      },
      "id": "e9a83d79-0f6b-4484-b7ac-a7f5e49603fd",
      "name": "Normalize Item",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        340,
        120
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "<APP_URL>/api/automation/news/rss-drafts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Accept",
              "value": "application/json"
            },
            {
              "name": "Authorization",
              "value": "Bearer <AUTOMATION_API_TOKEN>"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "cc8b6d04-3a9b-471c-b34c-cf76e8d549ac",
      "name": "POST RSS Draft To Laravel",

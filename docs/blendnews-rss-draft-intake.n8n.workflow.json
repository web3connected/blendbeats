        "jsonBody": "{\n  \"workflow_name\": \"BlendNews RSS Draft Intake\",\n  \"status\": \"success\",\n  \"message\": \"RSS intake created or skipped an item. Review Laravel automation logs for details.\",\n  \"payload\": {\n    \"feed_url\": \"<RSS_FEED_URL>\",\n    \"mode\": \"disabled-test-import\"\n  }\n}",
        "options": {}
      },
      "id": "029f9418-62d3-40b1-89c0-c6fd63881edb",

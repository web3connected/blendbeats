            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"workflow_name\": \"BlendNews RSS Draft Intake\",\n  \"status\": \"skipped\",\n  \"message\": \"RSS item skipped as a duplicate by Laravel.\",\n  \"payload\": {\n    \"reason\": \"duplicate_source\",\n    \"feed_url\": \"<RSS_FEED_URL>\"\n  }\n}",
        "options": {}
      },
      "id": "9f64dfd6-2ea5-444b-8f6e-8762db03e181",
      "name": "Optional Duplicate Log",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,

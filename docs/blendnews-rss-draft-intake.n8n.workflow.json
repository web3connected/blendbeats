      "typeVersion": 4.2,
      "position": [
        580,
        120
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.skipped === true }}",
              "value2": true
            }
          ]
        }
      },
      "id": "6d205749-0f41-4b86-82e2-49e924b04719",
      "name": "Was Duplicate?",

        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"workflow_name\": \"BlendNews RSS Draft Intake\",\n  \"status\": \"started\",\n  \"message\": \"RSS intake workflow started.\",\n  \"payload\": {\n    \"feed_url\": \"<RSS_FEED_URL>\",\n    \"mode\": \"disabled-test-import\"\n  }\n}",
        "options": {}
      },
